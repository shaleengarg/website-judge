 "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "8px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}], "paragraphs": [{"text": "Longer pieces, written slowly, mostly between midnight and four.", "length": 64, "rect": {"x": 424, "y": 274.48, "width": 592, "height": 27.19, "bottom": 301.67, "right": 1016, "area": 16095}, "styles": {"fontSize": "16px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(107, 107, 107)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(107, 107, 107)", "borderRightColor": "rgb(107, 107, 107)", "borderBottomColor": "rgb(107, 107, 107)", "borderLeftColor": "rgb(107, 107, 107)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "8px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "Returning to The Rings of Saturn after a decade, I find the fog has not lifted \u2014 only the reader has changed shape inside it.", "length": 125, "rect": {"x": 424, "y": 441.47, "width": 592, "height": 64.78, "bottom": 506.25, "right": 1016, "area": 38350.5}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "0px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "A meditation on the architecture of forced visibility, and what eight years of shared desks taught me about silence as a private resource.", "length": 138, "rect": {"x": 424, "y": 646.05, "width": 592, "height": 64.78, "bottom": 710.83, "right": 1016, "area": 38350.5}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "0px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "After three winters of broken sleep, I stopped fighting the dark hours and started taking notes \u2014 this is what they said back.", "length": 126, "rect": {"x": 424, "y": 850.63, "width": 592, "height": 64.78, "bottom": 915.41, "right": 1016, "area": 38350.5}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "0px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "On leaving the stacks for freelance copywriting, and the small grief of no longer being paid to know where things belong.", "length": 121, "rect": {"x": 424, "y": 1055.2, "width": 592, "height": 64.78, "bottom": 1119.98, "right": 1016, "area": 38350.5}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "0px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "Between the festivals and the slush, there is a city that belongs to people who walk slowly \u2014 and to the d\u00e9panneurs that stay open past two.", "length": 140, "rect": {"x": 424, "y": 1259.78, "width": 592, "height": 64.78, "bottom": 1324.56, "right": 1016, "area": 38350.5}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "0px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "A defense of the late hours for those whose best sentences refuse to arrive before the streetlights do.", "length": 103, "rect": {"x": 424, "y": 1464.36, "width": 592, "height": 64.78, "bottom": 1529.14, "right": 1016, "area": 38350.5}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "0px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "What I learned about my own language by spending two years trying, and mostly failing, to carry Ernaux into English in my notebook.", "length": 131, "rect": {"x": 424, "y": 1668.94, "width": 592, "height": 64.78, "bottom": 1733.72, "right": 1016, "area": 38350.5}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "0px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}], "links": [{"text": "journal", "inNav": true, "rect": {"x": 424, "y": 138.59, "width": 49.02, "height": 18, "bottom": 156.59, "right": 473.02, "area": 882.28}, "styles": {"fontSize": "16px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(192, 57, 43)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "inline", "position": "static", "borderTopColor": "rgb(192, 57, 43)", "bo