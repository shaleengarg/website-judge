hadow": "none", "backgroundImage": "none"}}, {"tag": "h2", "text": "Power outage, twenty-two minutes", "rect": {"x": 424, "y": 774.06, "width": 592, "height": 31.19, "bottom": 805.25, "right": 1016, "area": 18463}, "styles": {"fontSize": "24px", "fontWeight": "700", "fontFamily": "Georgia, \"Times New Roman\", Times, serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "0px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"tag": "h2", "text": "The stray on the fire escape", "rect": {"x": 424, "y": 1190.56, "width": 592, "height": 31.19, "bottom": 1221.75, "right": 1016, "area": 18463}, "styles": {"fontSize": "24px", "fontWeight": "700", "fontFamily": "Georgia, \"Times New Roman\", Times, serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "0px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"tag": "h2", "text": "Translating a sentence for an hour", "rect": {"x": 424, "y": 1542.28, "width": 592, "height": 31.19, "bottom": 1573.47, "right": 1016, "area": 18463}, "styles": {"fontSize": "24px", "fontWeight": "700", "fontFamily": "Georgia, \"Times New Roman\", Times, serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "0px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"tag": "h2", "text": "The all-night d\u00e9panneur", "rect": {"x": 424, "y": 1926.39, "width": 592, "height": 31.19, "bottom": 1957.58, "right": 1016, "area": 18463}, "styles": {"fontSize": "24px", "fontWeight": "700", "fontFamily": "Georgia, \"Times New Roman\", Times, serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "0px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}], "paragraphs": [{"text": "Recent entries, written between midnight and the first m\u00e9tro.", "length": 61, "rect": {"x": 424, "y": 292.56, "width": 592, "height": 32.39, "bottom": 324.95, "right": 1016, "area": 19175.25}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "8px", "marginRight": "0px", "marginBottom": "0px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "The bars had closed an hour earlier and the street had that swept-clean quality it only gets in November, when the wind moves cigarette ash but no leaves. I walked from Sherbrooke down to Mont-Royal without seeing more than four people, and three of them were waiting for the same bus.", "length": 285, "rect": {"x": 424, "y": 470.33, "width": 592, "height": 129.56, "bottom": 599.89, "right": 1016, "area": 76701}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "12px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "There was a man in a doorway reading a paperback by phone light. I didn't see the title. I wanted to ask but kept walking, the way you do when you understand someone has chosen their solitude on purpose.", "length": 203, "rect": {"x": 424, "y": 611.89, "width": 592, "height": 97.17, "bottom": 709.06, "right": 1016, "area": 57525.75}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "12px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "The lights went at 11:48 and came back at 12:10, and in between the building made sounds I had never heard it make \u2014 a settling, almost a sigh. I lit two candles I had been saving for nothing in particular and sat on the floor by the window.", "length": 241, "rect": {"x": 424, "y": 854.44, "width": 592, "height": 129.56, "bottom": 984, "right": 1016, "area": 76701}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "12px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "The street below stayed dark longer than the apartments. From four storeys up you could see exactly which neighbours had been awake: a square of kitchen, a blue television, a woman in a green sweater leaning into a refrigerator that no longer hummed.", "length": 250, "rect": {"x": 424, "y": 996, "width": 592, "height": 129.56, "bottom": 1125.56, "right": 1016, "area": 76701}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "12px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "He has been coming for three nights now \u2014 a thin tabby with one torn ear and an air of having read more books than I have. I left out a saucer of water and pretended not to watch from behind the curtain.", "length": 203, "rect": {"x": 424, "y": 1270.94, "width": 592, "height": 97.17, "bottom": 1368.11, "right": 1016, "area": 57525.75}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "12px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "He drank, sat for a long time looking at the alley, and then turned and looked directly at the window where I was hiding. I don't know what he saw. I don't know what I was hoping he'd see.", "length": 188, "rect": {"x": 424, "y": 1380.11, "width": 592, "height": 97.17, "bottom": 1477.28, "right": 1016, "area": 57525.75}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "12px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "I spent most of the night with one sentence from a French essay about provincial libraries \u2014 a sentence whose verb sat in the middle like a stone in a stream, parting everything around it. In English the verb wants to be at the front, eager, undignified.", "length": 254, "rect": {"x": 424, "y": 1622.66, "width": 592, "height": 129.56, "bottom": 1752.22, "right": 1016, "area": 76701}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "12px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "By 3 a.m. I had four versions and liked none of them. I went to bed and dreamed in subjunctives. In the morning the first version was the right one. It usually is.", "length": 163, "rect": {"x": 424, "y": 1764.22, "width": 592, "height": 97.17, "bottom": 1861.39, "right": 1016, "area": 57525.75}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "12px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "There is a d\u00e9panneur on the corner that has been open every hour I have ever needed it to be, run by a man who reads thick history books behind the counter and never looks up until you set something down. Last night it was a tin of sardines and a clementine.", "length": 258, "rect": {"x": 424, "y": 2006.77, "width": 592, "height": 129.56, "bottom": 2136.33, "right": 1016, "area": 76701}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "12px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "He weighed the clementine in his hand, said celle-ci est bonne, and went back to his book. It felt like a small benediction. I ate the clementine walking home and saved the sardines for a less hopeful evening.", "length": 209, "rect": {"x": 424, "y": 2148.33, "width": 592, "height": 97.17, "bottom": 2245.5, "right": 1016, "area": 57525.75}, "styles": {"fontSize": "18px", "fontWeight": "400", "fontFamily": "system-ui, -apple-system, \"system-ui\", \"Segoe UI\", Helvetica, Arial, sans-serif", "color": "rgb(26, 26, 26)", "backgroundColor": "rgba(0, 0, 0, 0)", "display": "block", "position": "static", "borderTopColor": "rgb(26, 26, 26)", "borderRightColor": "rgb(26, 26, 26)", "borderBottomColor": "rgb(26, 26, 26)", "borderLeftColor": "rgb(26, 26, 26)", "borderTopWidth": "0px", "borderRightWidth": "0px", "borderBottomWidth": "0px", "borderLeftWidth": "0px", "borderTopLeftRadius": "0px", "borderTopRightRadius": "0px", "borderBottomLeftRadius": "0px", "borderBottomRightRadius": "0px", "paddingTop": "0px", "paddingRight": "0px", "paddingBottom": "0px", "paddingLeft": "0px", "marginTop": "0px", "marginRight": "0px", "marginBottom": "12px", "marginLeft": "0px", "textAlign": "start", "boxShadow": "none", "backgroundImage": "none"}}, {"text": "Read older entries \u2192